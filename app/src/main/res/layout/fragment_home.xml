<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.example.moodymusicforandroid.ui.home.viewmodel.HomeViewModel" />
    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="96dp"
            android:paddingBottom="120dp">

            <!-- Hero Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="48dp">

                <TextView
                    android:id="@+id/tvHeroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="听，风吹过山谷的声音"
                    android:textSize="36sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvHeroSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="在这个嘈杂的世界，为你保留一方静谧。让音乐成为身心的良药。"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface_variant"
                    android:alpha="0.8"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- Featured Section: 余音·回响 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="48dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFeaturedTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="余音 · 回响"
                            android:textSize="20sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            android:fontFamily="serif" />

                        <View
                            android:layout_width="48dp"
                            android:layout_height="4dp"
                            android:background="@color/tertiary"
                            android:alpha="0.6"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSeeAllFeatured"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="查看全部"
                        android:textSize="12sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:drawableEnd="@drawable/ic_home"
                        android:drawablePadding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless" />

                </LinearLayout>

                <!-- Featured Cards Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Large Featured Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvFeaturedMain"
                        android:layout_width="0dp"
                        android:layout_height="240dp"
                        android:layout_weight="7"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivFeaturedMain"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:alpha="0.9"
                            android:contentDescription="Featured"
                            tools:src="@drawable/ic_home" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:background="@drawable/gradient_overlay"
                            android:padding="20dp"
                            android:gravity="bottom">

                            <TextView
                                android:id="@+id/tvFeaturedTag"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="今日推荐"
                                android:textSize="8sp"
                                android:textColor="@color/on_tertiary"
                                android:textStyle="bold"
                                android:letterSpacing="0.15"
                                android:background="@color/tertiary"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:id="@+id/tvFeaturedCardTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="山间雾起时"
                                android:textSize="20sp"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/tvFeaturedDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="白噪音与长笛的对话，带你重返大自然的呼吸频率。"
                                android:textSize="12sp"
                                android:textColor="@color/white"
                                android:alpha="0.8"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Side Cards -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="5"
                        android:orientation="vertical">

                        <!-- Small Card 1 -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cvFeatured1"
                            android:layout_width="match_parent"
                            android:layout_height="112dp"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="@color/surface_container_lowest"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:id="@+id/ivFeatured1"
                                    android:layout_width="96dp"
                                    android:layout_height="96dp"
                                    android:scaleType="centerCrop"
                                    android:contentDescription="Album"
                                    tools:src="@drawable/ic_home" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="16dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvFeatured1Title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="深海潜行"
                                        android:textSize="16sp"
                                        android:textColor="@color/on_surface"
                                        android:textStyle="bold"
                                        android:fontFamily="serif"
                                        android:layout_marginBottom="4dp" />

                                    <TextView
                                        android:id="@+id/tvFeatured1Desc"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="45分钟 · 沉浸式冥想"
                                        android:textSize="10sp"
                                        android:textColor="@color/on_surface_variant"
                                        android:layout_marginBottom="12dp" />

                                    <ImageView
                                        android:id="@+id/ivFeatured1Play"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_play_circle"
                                        app:tint="@color/primary" />

                                </LinearLayout>

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Small Card 2 -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cvFeatured2"
                            android:layout_width="match_parent"
                            android:layout_height="112dp"
                            app:cardBackgroundColor="@color/secondary_container"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="20dp"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="16dp">

                                    <ImageView
                                        android:id="@+id/ivFeatured2Icon"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/ic_search"
                                        app:tint="@color/primary" />

                                    <TextView
                                        android:id="@+id/tvFeatured2Tag"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Natural"
                                        android:textSize="8sp"
                                        android:textColor="@color/on_secondary_container"
                                        android:alpha="0.6"
                                        android:textStyle="bold"
                                        android:letterSpacing="0.1"
                                        android:textAllCaps="true"
                                        android:layout_marginStart="8dp"
                                        android:gravity="end" />

                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tvFeatured2Title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="雨夜回廊"
                                    android:textSize="16sp"
                                    android:textColor="@color/on_secondary_container"
                                    android:textStyle="bold"
                                    android:fontFamily="serif"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tvFeatured2Desc"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="听见屋檐落下的节奏"
                                    android:textSize="10sp"
                                    android:textColor="@color/on_secondary_container"
                                    android:alpha="0.8" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Articles Section: 读物体志 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="32dp">

                    <TextView
                        android:id="@+id/tvArticlesTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="读物 · 志"
                        android:textSize="20sp"
                        android:textColor="@color/on_surface"
                        android:textStyle="bold"
                        android:fontFamily="serif" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/outline_variant"
                        android:alpha="0.2"
                        android:layout_marginStart="24dp" />

                </LinearLayout>

                <!-- Articles Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Article Card 1 -->
                    <LinearLayout
                        android:id="@+id/llArticle1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="@color/surface_container"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/ivArticle1"
                                android:layout_width="match_parent"
                                android:layout_height="180dp"
                                android:scaleType="centerCrop"
                                android:contentDescription="Article"
                                tools:src="@drawable/ic_home" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvArticle1Tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vol. 124 · 2024"
                            android:textSize="8sp"
                            android:textColor="@color/tertiary"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textAllCaps="true"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvArticle1Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="民谣里的土地与乡愁"
                            android:textSize="16sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvArticle1Desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="那些从土地里生长出来的旋律，为何总能触动我们内心最柔软的部分？"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                    <!-- Article Card 2 -->
                    <LinearLayout
                        android:id="@+id/llArticle2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="@color/surface_container"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/ivArticle2"
                                android:layout_width="match_parent"
                                android:layout_height="180dp"
                                android:scaleType="centerCrop"
                                android:contentDescription="Article"
                                tools:src="@drawable/ic_home" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvArticle2Tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vol. 123 · 2024"
                            android:textSize="8sp"
                            android:textColor="@color/tertiary"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textAllCaps="true"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvArticle2Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="声音生态学：重建与自然的关系"
                            android:textSize="16sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvArticle2Desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="在这个数字化的时代，如何通过聆听来重新连接我们所处的环境？"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                    <!-- Article Card 3 -->
                    <LinearLayout
                        android:id="@+id/llArticle3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="@color/surface_container"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/ivArticle3"
                                android:layout_width="match_parent"
                                android:layout_height="180dp"
                                android:scaleType="centerCrop"
                                android:contentDescription="Article"
                                tools:src="@drawable/ic_home" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvArticle3Tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vol. 122 · 2024"
                            android:textSize="8sp"
                            android:textColor="@color/tertiary"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textAllCaps="true"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvArticle3Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="慢下来的艺术：黑胶唱片的复兴"
                            android:textSize="16sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvArticle3Desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="从实体触感到模拟音质，黑胶唱片如何在这个快节奏的时代教我们珍惜当下。"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</layout>
