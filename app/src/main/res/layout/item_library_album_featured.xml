<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cvAlbumFeatured"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/surface_container_low"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivAlbumFeatured"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                android:contentDescription="Album"
                tools:src="@drawable/ic_home" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAlbumFeaturedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="夜的宁静"
                android:textSize="18sp"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvAlbumFeaturedArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="白日梦乐团"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
