<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.example.moodymusicforandroid.ui.home.viewmodel.LibraryViewModel" />
    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="96dp"
            android:paddingBottom="120dp">

            <!-- Favorite Albums Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="48dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/tvAlbumsTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="收藏专辑"
                        android:textSize="20sp"
                        android:textColor="@color/on_surface"
                        android:textStyle="bold"
                        android:fontFamily="serif" />

                    <TextView
                        android:id="@+id/tvSeeAllAlbums"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="查看全部"
                        android:textSize="12sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless" />

                </LinearLayout>

                <!-- Albums Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Large Featured Album -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvAlbumFeatured"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/ivAlbumFeatured"
                                    android:layout_width="match_parent"
                                    android:layout_height="160dp"
                                    android:scaleType="centerCrop"
                                    android:contentDescription="Album"
                                    tools:src="@drawable/ic_home" />

                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvAlbumFeaturedTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="夜的宁静"
                                    android:textSize="18sp"
                                    android:textColor="@color/on_surface"
                                    android:textStyle="bold"
                                    android:fontFamily="serif"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tvAlbumFeaturedArtist"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="白日梦乐团"
                                    android:textSize="12sp"
                                    android:textColor="@color/on_surface_variant" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Side Albums Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:orientation="vertical">

                        <!-- Small Album 1 -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cvAlbum1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:cardBackgroundColor="@color/surface_container_low"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp">

                                    <ImageView
                                        android:id="@+id/ivAlbum1"
                                        android:layout_width="match_parent"
                                        android:layout_height="80dp"
                                        android:scaleType="centerCrop"
                                        android:contentDescription="Album"
                                        tools:src="@drawable/ic_home" />

                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvAlbum1Title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="森林回响"
                                    android:textSize="12sp"
                                    android:textColor="@color/on_surface"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:layout_marginBottom="2dp" />

                                <TextView
                                    android:id="@+id/tvAlbum1Artist"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="自然主义者"
                                    android:textSize="10sp"
                                    android:textColor="@color/on_surface_variant"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Small Album 2 -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cvAlbum2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/surface_container_low"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp">

                                    <ImageView
                                        android:id="@+id/ivAlbum2"
                                        android:layout_width="match_parent"
                                        android:layout_height="80dp"
                                        android:scaleType="centerCrop"
                                        android:contentDescription="Album"
                                        tools:src="@drawable/ic_home" />

                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvAlbum2Title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="潮汐呼吸"
                                    android:textSize="12sp"
                                    android:textColor="@color/on_surface"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:layout_marginBottom="2dp" />

                                <TextView
                                    android:id="@+id/tvAlbum2Artist"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="海浪诗人"
                                    android:textSize="10sp"
                                    android:textColor="@color/on_surface_variant"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Following Artists Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvArtistsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关注的艺人"
                    android:textSize="20sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_marginBottom="24dp" />

                <!-- Artist 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvFollowingArtist1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardCornerRadius="32dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/ivFollowingArtist1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="Artist"
                                tools:src="@drawable/ic_home" />

                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="24dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFollowingArtist1Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="大提琴鸣响"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvFollowingArtist1Info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="342k 听众 • 治愈系"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFollowing1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="正在关注"
                            android:textSize="10sp"
                            android:textColor="@color/primary"
                            app:cornerRadius="16dp"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@android:color/transparent" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Artist 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvFollowingArtist2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardCornerRadius="32dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/ivFollowingArtist2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="Artist"
                                tools:src="@drawable/ic_home" />

                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="24dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFollowingArtist2Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="林间风"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvFollowingArtist2Info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="128k 听众 • 民谣"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFollowing2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="正在关注"
                            android:textSize="10sp"
                            android:textColor="@color/primary"
                            app:cornerRadius="16dp"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@android:color/transparent" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Artist 3 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvFollowingArtist3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardCornerRadius="32dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/ivFollowingArtist3"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="Artist"
                                tools:src="@drawable/ic_home" />

                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="24dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFollowingArtist3Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="空灵笛音"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvFollowingArtist3Info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="85k 听众 • 冥想"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFollowing3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="正在关注"
                            android:textSize="10sp"
                            android:textColor="@color/primary"
                            app:cornerRadius="16dp"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@android:color/transparent" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</layout>
