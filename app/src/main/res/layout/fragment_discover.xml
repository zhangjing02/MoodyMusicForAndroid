<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.example.moodymusicforandroid.ui.home.viewmodel.DiscoverViewModel" />
    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="96dp"
            android:paddingBottom="120dp">

            <!-- Search Bar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvSearch"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/surface_container_highest"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <ImageView
                        android:id="@+id/ivSearchIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/outline" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="搜索艺术家、流派或乐器"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:singleLine="true" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Category Tabs -->
            <HorizontalScrollView
                android:id="@+id/hvCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="-24dp"
                android:layout_marginEnd="-24dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:scrollbars="none"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/llCategoryAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:id="@+id/tvCategoryAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="全部"
                            android:textSize="14sp"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <View
                            android:id="@+id/vIndicatorAll"
                            android:layout_width="16dp"
                            android:layout_height="2dp"
                            android:background="@color/primary"
                            android:alpha="1.0" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llCategory1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="12dp"
                        android:layout_marginStart="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:id="@+id/tvCategory1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="华语"
                            android:textSize="14sp"
                            android:textColor="@color/outline"
                            android:layout_marginBottom="8dp" />

                        <View
                            android:id="@+id/vIndicator1"
                            android:layout_width="16dp"
                            android:layout_height="2dp"
                            android:background="@color/primary"
                            android:alpha="0.0"
                            android:visibility="invisible" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llCategory2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="12dp"
                        android:layout_marginStart="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:id="@+id/tvCategory2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="港台"
                            android:textSize="14sp"
                            android:textColor="@color/outline"
                            android:layout_marginBottom="8dp" />

                        <View
                            android:id="@+id/vIndicator2"
                            android:layout_width="16dp"
                            android:layout_height="2dp"
                            android:background="@color/primary"
                            android:alpha="0.0"
                            android:visibility="invisible" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llCategory3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="12dp"
                        android:layout_marginStart="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:id="@+id/tvCategory3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="摇滚"
                            android:textSize="14sp"
                            android:textColor="@color/outline"
                            android:layout_marginBottom="8dp" />

                        <View
                            android:id="@+id/vIndicator3"
                            android:layout_width="16dp"
                            android:layout_height="2dp"
                            android:background="@color/primary"
                            android:alpha="0.0"
                            android:visibility="invisible" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llCategory4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="12dp"
                        android:layout_marginStart="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:id="@+id/tvCategory4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="民谣"
                            android:textSize="14sp"
                            android:textColor="@color/outline"
                            android:layout_marginBottom="8dp" />

                        <View
                            android:id="@+id/vIndicator4"
                            android:layout_width="16dp"
                            android:layout_height="2dp"
                            android:background="@color/primary"
                            android:alpha="0.0"
                            android:visibility="invisible" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llCategory5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="12dp"
                        android:layout_marginStart="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:id="@+id/tvCategory5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R&amp;B"
                            android:textSize="14sp"
                            android:textColor="@color/outline"
                            android:layout_marginBottom="8dp" />

                        <View
                            android:id="@+id/vIndicator5"
                            android:layout_width="16dp"
                            android:layout_height="2dp"
                            android:background="@color/primary"
                            android:alpha="0.0"
                            android:visibility="invisible" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llCategory6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="12dp"
                        android:layout_marginStart="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:id="@+id/tvCategory6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="音乐综艺"
                            android:textSize="14sp"
                            android:textColor="@color/outline"
                            android:layout_marginBottom="8dp" />

                        <View
                            android:id="@+id/vIndicator6"
                            android:layout_width="16dp"
                            android:layout_height="2dp"
                            android:background="@color/primary"
                            android:alpha="0.0"
                            android:visibility="invisible" />

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Artist List Section A -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="40dp">

                <TextView
                    android:id="@+id/tvSectionA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textSize="10sp"
                    android:textColor="@color/outline"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Artist 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvArtist1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/ivArtist1"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:scaleType="centerCrop"
                            android:contentDescription="Artist"
                            tools:src="@drawable/ic_home" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvArtist1Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Acoustic Echoes"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvArtist1Albums"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="42 张专辑"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Artist 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvArtist2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/ivArtist2"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:scaleType="centerCrop"
                            android:contentDescription="Artist"
                            tools:src="@drawable/ic_home" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvArtist2Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ambient Rain"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvArtist2Albums"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="128 张专辑"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Artist List Section B -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSectionB"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B"
                    android:textSize="10sp"
                    android:textColor="@color/outline"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Artist 3 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvArtist3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/ivArtist3"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:scaleType="centerCrop"
                            android:contentDescription="Artist"
                            tools:src="@drawable/ic_home" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvArtist3Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bamboo Flute"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvArtist3Albums"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15 张专辑"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</layout>
