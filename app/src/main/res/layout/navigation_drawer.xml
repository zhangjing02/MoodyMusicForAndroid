<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:background="@color/surface"
        android:clickable="true"
        android:focusable="true">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/drawerHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/primary_container"
            android:padding="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- App Name -->
            <TextView
                android:id="@+id/tvDrawerAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="音信"
                android:textSize="28sp"
                android:textColor="@color/on_primary_container"
                android:letterSpacing="0.1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvDrawerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="听，风吹过的声音"
                android:textSize="12sp"
                android:textColor="@color/on_primary_container"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvDrawerAppName"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Theme Section -->
        <TextView
            android:id="@+id/tvThemeSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="主题"
            android:textSize="14sp"
            android:textColor="@color/primary"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp"
            app:layout_constraintTop_toBottomOf="@id/drawerHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Theme Options -->
        <RadioGroup
            android:id="@+id/rgTheme"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvThemeSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rbThemeDefault"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="默认绿"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:buttonTint="@color/primary"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <RadioButton
                android:id="@+id/rbThemeOcean"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="海洋蓝"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:buttonTint="@color/primary"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <RadioButton
                android:id="@+id/rbThemeSunset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="日落橙"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:buttonTint="@color/primary"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <RadioButton
                android:id="@+id/rbThemeNight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暗夜紫"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:buttonTint="@color/primary"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

        </RadioGroup>

        <!-- Font Section -->
        <TextView
            android:id="@+id/tvFontSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="字体风格"
            android:textSize="14sp"
            android:textColor="@color/primary"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp"
            app:layout_constraintTop_toBottomOf="@id/rgTheme"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Font Options -->
        <RadioGroup
            android:id="@+id/rgFont"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvFontSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rbFontHandwriting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="手写飘逸"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:buttonTint="@color/primary"
                android:fontFamily="@font/lxgw_wenkai_gb_regular"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <RadioButton
                android:id="@+id/rbFontModern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="现代轻盈"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:buttonTint="@color/primary"
                android:fontFamily="@font/source_han_serif_sc_regular"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <RadioButton
                android:id="@+id/rbFontElegant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="清秀文艺"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:buttonTint="@color/primary"
                android:fontFamily="@font/source_han_serif_sc_regular"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

        </RadioGroup>

        <!-- Close Button -->
        <ImageView
            android:id="@+id/ivCloseDrawer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:padding="8dp"
            android:layout_margin="16dp"
            android:contentDescription="Close"
            app:tint="@color/on_surface_variant"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
