<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/llArticle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/surface_container"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/ivArticle"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:contentDescription="Article"
            tools:src="@drawable/ic_home" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvArticleTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vol. 124 · 2024"
        android:textAppearance="@style/TextAppearance.Moody.LabelSmall"
        android:textColor="@color/tertiary"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvArticleTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="民谣里的土地与乡愁"
        android:textAppearance="@style/TextAppearance.Moody.TitleMedium"
        android:textColor="@color/on_surface"
        android:letterSpacing="0"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvArticleDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="那些从土地里生长出来的旋律，为何总能触动我们内心最柔软的部分？"
        android:textAppearance="@style/TextAppearance.Moody.BodySmall"
        android:textColor="@color/on_surface_variant"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="20dp" />

</LinearLayout>
