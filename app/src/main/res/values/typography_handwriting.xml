<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        方案1: 手写飘逸风
        特点：楷体风格，飘逸洒脱，文艺复古

        标题字体：霞鹜文楷 GB（需要下载）
        下载地址：https://github.com/lxgw/LxgwWenkaiGB/releases
    -->

    <!-- Display Styles - Hero标题 -->
    <style name="TextAppearance.MoodyHandwriting.DisplayLarge" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">57sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">0sp</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.DisplayMedium" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">45sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">0sp</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.DisplaySmall" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">0sp</item>
    </style>

    <!-- Headline Styles - 章节标题 -->
    <style name="TextAppearance.MoodyHandwriting.HeadlineLarge" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.HeadlineMedium" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.HeadlineSmall" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <!-- Title Styles - 卡片标题 -->
    <style name="TextAppearance.MoodyHandwriting.TitleLarge" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.TitleMedium" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:lineSpacingExtra">1sp</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.TitleSmall" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:lineSpacingExtra">1sp</item>
    </style>

    <!-- Body Styles - 正文 -->
    <style name="TextAppearance.MoodyHandwriting.BodyLarge" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:lineSpacingExtra">6sp</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.BodyMedium" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:letterSpacing">0.025</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.BodySmall" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <!-- Label Styles - 标签/按钮 -->
    <style name="TextAppearance.MoodyHandwriting.LabelLarge" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.LabelMedium" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.MoodyHandwriting.LabelSmall" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Special Styles -->
    <style name="TextAppearance.MoodyHandwriting.Hero" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

</resources>
