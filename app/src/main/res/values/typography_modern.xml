<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        方案2: 现代轻盈风
        特点：极简纤细，干净流畅，科技感

        使用现有字体，通过调整字重实现轻盈效果
    -->

    <!-- Display Styles - Hero标题 -->
    <style name="TextAppearance.MoodyModern.DisplayLarge" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:fontFamily">@font/source_han_serif_sc_regular</item>
        <item name="android:textSize">57sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:lineSpacingExtra">-2sp</item>
    </style>

    <style name="TextAppearance.MoodyModern.DisplayMedium" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:fontFamily">@font/source_han_serif_sc_regular</item>
        <item name="android:textSize">45sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">0sp</item>
    </style>

    <style name="TextAppearance.MoodyModern.DisplaySmall" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:fontFamily">@font/source_han_serif_sc_regular</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">0sp</item>
    </style>

    <!-- Headline Styles - 章节标题 -->
    <style name="TextAppearance.MoodyModern.HeadlineLarge" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">@font/source_han_serif_sc_regular</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="TextAppearance.MoodyModern.HeadlineMedium" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:fontFamily">@font/source_han_serif_sc_regular</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <style name="TextAppearance.MoodyModern.HeadlineSmall" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/source_han_serif_sc_regular</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <!-- Title Styles - 卡片标题 -->
    <style name="TextAppearance.MoodyModern.TitleLarge" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:fontFamily">@font/source_han_serif_sc_regular</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <style name="TextAppearance.MoodyModern.TitleMedium" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:lineSpacingExtra">1sp</item>
    </style>

    <style name="TextAppearance.MoodyModern.TitleSmall" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:lineSpacingExtra">1sp</item>
    </style>

    <!-- Body Styles - 正文 -->
    <style name="TextAppearance.MoodyModern.BodyLarge" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:lineSpacingExtra">6sp</item>
    </style>

    <style name="TextAppearance.MoodyModern.BodyMedium" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:letterSpacing">0.025</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="TextAppearance.MoodyModern.BodySmall" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <!-- Label Styles - 标签/按钮 -->
    <style name="TextAppearance.MoodyModern.LabelLarge" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.MoodyModern.LabelMedium" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.MoodyModern.LabelSmall" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Special Styles -->
    <style name="TextAppearance.MoodyModern.Hero" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/source_han_serif_sc_regular</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

</resources>
