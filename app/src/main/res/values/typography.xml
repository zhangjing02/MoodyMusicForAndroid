<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Typography System for 音信 App
        设计原则：优雅、文艺、易读

        支持自定义字体（思源黑体/宋体）和系统字体自动降级
    -->

    <!-- Display Styles - 用于特殊强调，如Hero标题 -->
    <style name="TextAppearance.Moody.DisplayLarge" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">57sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">0sp</item>
    </style>

    <style name="TextAppearance.Moody.DisplayMedium" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">45sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">0sp</item>
    </style>

    <style name="TextAppearance.Moody.DisplaySmall" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">0sp</item>
    </style>

    <!-- Headline Styles - 用于页面标题、章节标题 -->
    <style name="TextAppearance.Moody.HeadlineLarge" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="TextAppearance.Moody.HeadlineMedium" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <style name="TextAppearance.Moody.HeadlineSmall" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <!-- Title Styles - 用于卡片标题、列表项标题 -->
    <style name="TextAppearance.Moody.TitleLarge" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <style name="TextAppearance.Moody.TitleMedium" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:lineSpacingExtra">1sp</item>
    </style>

    <style name="TextAppearance.Moody.TitleSmall" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:lineSpacingExtra">1sp</item>
    </style>

    <!-- Body Styles - 用于正文内容 -->
    <style name="TextAppearance.Moody.BodyLarge" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:lineSpacingExtra">6sp</item>
    </style>

    <style name="TextAppearance.Moody.BodyMedium" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:letterSpacing">0.025</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="TextAppearance.Moody.BodySmall" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <!-- Label Styles - 用于标签、按钮、胶囊文本 -->
    <style name="TextAppearance.Moody.LabelLarge" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Moody.LabelMedium" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Moody.LabelSmall" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Special Styles -->
    <!-- Hero标题 - 用于首页主标题 -->
    <style name="TextAppearance.MoodyHero" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <!-- 副标题 -->
    <style name="TextAppearance.MoodySubtitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/source_han_sans_sc_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <!-- 标签式文本 -->
    <style name="TextAppearance.MoodyTag" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/lxgw_wenkai_gb_regular</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!--
        自定义字体样式（如果字体文件存在）
        当字体文件添加到 res/font/ 目录后，取消下面的注释
    -->

